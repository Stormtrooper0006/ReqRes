        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Correct JSON response\", function () {",
                  "    pm.expect(jsonData.page).to.eql(1);",
                  "    pm.expect(jsonData.per_page).to.eql(6);",
                  "    pm.expect(jsonData.data[0].id).to.eql(1);",
                  "});",
                  "",
                  "pm.test(\"Check if a user exist\", function () {",
                  "    const charles = jsonData.data.some(user => user.first_name === 'Charles');",
                  "    pm.expect(charles).to.be.true;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users?page=1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
